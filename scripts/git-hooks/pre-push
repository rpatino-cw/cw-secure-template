#!/usr/bin/env bash
# === CW Secure Template — Pre-Push Hook ===
# Runs tests before your code leaves your machine.
set -uo pipefail

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

echo ""
echo -e "${DIM}  Running tests before push...${NC}"

FAILED=0

if [ -f go/go.mod ]; then
    echo -e "  ${DIM}Go tests...${NC}"
    (cd go && go test -race -count=1 ./... 2>&1 | tail -5) || FAILED=1
fi

if [ -f python/pyproject.toml ]; then
    echo -e "  ${DIM}Python tests...${NC}"
    (cd python && python -m pytest --tb=short -q 2>&1 | tail -5) || FAILED=1
fi

if [ "$FAILED" -ne 0 ]; then
    echo ""
    echo -e "  ${RED}${BOLD}STOP — Your push was blocked.${NC}"
    echo ""
    echo -e "  ${BOLD}What happened:${NC}  One or more tests failed."
    echo -e "  ${BOLD}Why it matters:${NC} Broken code shouldn't reach the team's repository."
    echo -e "  ${BOLD}How to fix it:${NC}"
    echo "    1. Run ${GREEN}make test${NC} to see which tests failed"
    echo "    2. Fix the failing tests"
    echo "    3. Commit the fix"
    echo "    4. Try pushing again"
    echo ""
    exit 1
fi

echo -e "  ${GREEN}All tests passed. Pushing...${NC}"
echo ""
