#!/usr/bin/env bash
# === CW Secure Framework — Pre-Push Hook ===
# Runs tests, security checks, and room config lint before code leaves your machine.
set -uo pipefail

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

echo ""
echo -e "${DIM}  Pre-push checks...${NC}"

FAILED=0

# ── 0. Branch mode: block direct pushes to main ──
# Trunk mode (default): main pushes allowed — pre-push checks ARE the gate
# Branch mode (opt-in): set BRANCH_MODE=1 in .env or env to require PRs
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")

if [ "${BRANCH_MODE:-}" = "1" ]; then
  REMOTE_REF=""
  while read local_ref local_sha remote_ref remote_sha; do
    REMOTE_REF="$remote_ref"
  done

  if [[ "$CURRENT_BRANCH" == "main" || "$REMOTE_REF" == *"refs/heads/main"* ]]; then
    REMOTE_COUNT=$(git rev-list --count origin/main 2>/dev/null || echo "0")
    if [ "$REMOTE_COUNT" -gt 0 ]; then
      echo -e "  ${RED}${BOLD}STOP — Branch mode is on. Cannot push directly to main.${NC}"
      echo ""
      echo -e "  ${BOLD}How to fix:${NC}"
      echo "    1. Create a branch:  ${GREEN}make branch NAME=my-feature${NC}"
      echo "    2. Push the branch:  ${GREEN}git push -u origin my-feature${NC}"
      echo "    3. Open a PR:        ${GREEN}make pr${NC}"
      echo ""
      echo -e "  ${DIM}Disable branch mode: remove BRANCH_MODE=1 from .env${NC}"
      echo ""
      exit 1
    fi
  fi
fi

# ── 1. Tests ──
if [ -f go/go.mod ]; then
    echo -e "  ${DIM}Go tests...${NC}"
    (cd go && go test -race -count=1 ./... 2>&1 | tail -5) || FAILED=1
fi

if [ -f python/pyproject.toml ]; then
    echo -e "  ${DIM}Python tests...${NC}"
    (cd python && python -m pytest --tb=short -q 2>&1 | tail -5) || FAILED=1
fi

# ── 2. Critical security checks (fast subset of doctor.sh) ──
echo -e "  ${DIM}Security checks...${NC}"

# Hardcoded secrets in source
SECRET_HITS=$(grep -rn --include="*.go" --include="*.py" -E "(password|secret|token|api_key)\s*[:=]\s*[\"'][^\"']{8,}" go/ python/ 2>/dev/null | grep -v "_test\." | grep -v ".example" | wc -l | tr -d ' ')
if [ "$SECRET_HITS" -gt 0 ]; then
    echo -e "  ${RED}[FAIL]${NC} Found $SECRET_HITS potential hardcoded secrets"
    FAILED=1
fi

# Dangerous functions
DANGEROUS=$(grep -rn --include="*.py" -E "eval\(|exec\(|pickle\.loads|os\.system\(|yaml\.load\(" python/src/ 2>/dev/null | wc -l | tr -d ' ')
if [ "$DANGEROUS" -gt 0 ]; then
    echo -e "  ${RED}[FAIL]${NC} Found $DANGEROUS dangerous Python functions"
    FAILED=1
fi

DANGEROUS_GO=$(grep -rn --include="*.go" -E 'InsecureSkipVerify:\s*true|template\.HTML\(' go/ 2>/dev/null | grep -v "_test\." | wc -l | tr -d ' ')
if [ "$DANGEROUS_GO" -gt 0 ]; then
    echo -e "  ${RED}[FAIL]${NC} Found $DANGEROUS_GO dangerous Go patterns"
    FAILED=1
fi

# Guard files intact
if [ ! -f CLAUDE.md ]; then
    echo -e "  ${RED}[FAIL]${NC} CLAUDE.md missing — security guardrails gone"
    FAILED=1
fi

if [ ! -f scripts/guard.sh ]; then
    echo -e "  ${RED}[FAIL]${NC} guard.sh missing — edit enforcement gone"
    FAILED=1
fi

# ── 3. Room config lint ──
if [ -f rooms.json ]; then
    echo -e "  ${DIM}Room config lint...${NC}"
    if ! bash scripts/room-lint.sh; then
        FAILED=1
    fi
fi

# ── 4. Agent code review ──
echo -e "  ${DIM}Agent code review...${NC}"
if ! bash scripts/agent-review.sh; then
    FAILED=1
fi

# ── Result ──
if [ "$FAILED" -ne 0 ]; then
    echo ""
    echo -e "  ${RED}${BOLD}STOP — Push blocked.${NC}"
    echo ""
    echo -e "  ${BOLD}How to fix:${NC}"
    echo "    1. Read the failures above"
    echo "    2. Run ${GREEN}make check${NC} for the full report"
    echo "    3. Commit fixes, then push again"
    echo ""
    exit 1
fi

echo -e "  ${GREEN}All checks passed. Pushing...${NC}"

# ── 5. Post-push repo lint (informational — never blocks) ──
if [ -f scripts/repo-lint.sh ]; then
  bash scripts/repo-lint.sh 2>/dev/null || true
fi
