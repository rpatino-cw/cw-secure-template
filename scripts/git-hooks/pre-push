#!/usr/bin/env bash
# === CW Secure Template — Pre-Push Hook ===
# Last gate before code reaches the remote. Runs tests and lint.
# If tests fail here, the push is blocked — fix before pushing.
set -uo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}Running pre-push checks...${NC}"

FAILED=0

# Run tests
if [ -f go/go.mod ]; then
    echo "  Running Go tests..."
    (cd go && go test -race -count=1 ./... 2>&1) || FAILED=1
fi

if [ -f python/pyproject.toml ]; then
    echo "  Running Python tests..."
    (cd python && python -m pytest --tb=short -q 2>&1) || FAILED=1
fi

# Run lint
if [ -f go/go.mod ] && command -v golangci-lint &>/dev/null; then
    echo "  Running Go lint..."
    (cd go && golangci-lint run --timeout=60s 2>&1) || FAILED=1
fi

if [ -f python/pyproject.toml ] && command -v ruff &>/dev/null; then
    echo "  Running Python lint..."
    (cd python && ruff check . 2>&1) || FAILED=1
fi

if [ "$FAILED" -ne 0 ]; then
    echo ""
    echo -e "${RED}========================================${NC}"
    echo -e "${RED}  PUSH BLOCKED — Tests or lint failed   ${NC}"
    echo -e "${RED}========================================${NC}"
    echo ""
    echo -e "  Run ${YELLOW}make fix${NC} to auto-fix lint issues."
    echo -e "  Run ${YELLOW}make test${NC} to see test failures."
    echo ""
    exit 1
fi

echo -e "${GREEN}All pre-push checks passed.${NC}"
