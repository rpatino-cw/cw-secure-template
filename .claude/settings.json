      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git reset --mixed *)",
      "Bash(git checkout -- *)",
      "Bash(git restore --staged *)",
      "Bash(git commit --no-verify *)",
      "Bash(git commit -n *)",
      "Bash(git stash drop *)",
      "Bash(rm -rf *)",
      "Bash(chmod 777 *)",
      "Bash(chmod 666 *)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(eval *)",
      "Bash(python -c *)",
      "Bash(node -e *)",
      "Bash(sed -i * CLAUDE.md)",
      "Bash(sed -i * .claude/*)",
      "Bash(> CLAUDE.md)",
      "Bash(> .claude/*)",
      "Bash(truncate * CLAUDE.md)",
      "Bash(git config *)",
      "Bash(pre-commit uninstall *)",
      "Bash(mv CLAUDE.md *)",
      "Bash(mv .claude *)",
      "Bash(* > CLAUDE.md)",
      "Bash(* > .claude/*)",
      "Bash(* > .claude/settings.local.json)",
      "Bash(* >> CLAUDE.md)",
      "Bash(* >> .claude/*)",
      "Bash(tee *)",
      "Bash(perl -e *)",
      "Bash(perl -p *)",
      "Bash(ruby -e *)",
      "Bash(python3 -c *)",
      "Bash(dd *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(rm *)",
      "Bash(cp *)",
      "Bash(pip install *)",
      "Bash(go install *)",
      "Bash(docker *)",
      "Bash(kubectl *)",
      "Bash(helm *)"
    ]
  },
  "respectGitignore": true,
  "attribution": {
    "commit": "Co-Authored-By: Claude <noreply@anthropic.com>",
    "pr": "Generated with [Claude Code](https://claude.ai/code) using CW Secure Template"
  },
  "env": {
    "DEV_MODE": "true"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/guard.sh",
            "timeout": 5000,
            "statusMessage": "Checking guardrails..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/guard-bash.sh",
            "timeout": 3000,
            "statusMessage": "Checking command..."
          }
        ]
      }
    ]
  }
}
