# ╔══════════════════════════════════════════════════════════════════╗
# ║  CW SECURE FRAMEWORK — .gitignore                               ║
# ║  This file is AGGRESSIVE by design. It blocks every known       ║
# ║  secret, credential, and key pattern. If a legitimate file      ║
# ║  gets blocked, add a specific !exception — never weaken the     ║
# ║  rules.                                                         ║
# ╚══════════════════════════════════════════════════════════════════╝

# ══════════════════════════════════════
# SECRETS & CREDENTIALS — NEVER COMMIT
# ══════════════════════════════════════

# Environment files (the #1 source of leaked secrets)
.env
.env.*
.env.local
.env.development
.env.staging
.env.production
.env.test
!.env.example

# Certificates and keys
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
*.jks
*.keystore
*.truststore
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_dsa
*.pub
!deploy/  # Don't block deploy/ directory

# Claude Code local overrides (created by make secure-mode, per-clone)
.claude/settings.local.json

# Credential files
credentials.json
service-account*.json
token.json
token.txt
secrets/
config.py
settings_local.py
**/secret.yaml
**/secret.yml
*secrets.json
*secrets.yaml
*secrets.yml

# ══════════════════════════════════════
# API KEYS / TOKENS — EVERY PATTERN
# ══════════════════════════════════════

**/apikey*
**/api_key*
**/api-key*
**/*token*.json
**/*credentials*
**/*password*
**/.htpasswd
**/.netrc
**/.npmrc
**/.pypirc

# Cloud provider credentials
.aws/
.azure/
.gcp/
gcloud-*.json
application_default_credentials.json
kubeconfig
kubeconfig.*
.kube/config

# Terraform (contains secrets in state)
*.tfstate
*.tfstate.*
*.tfvars
.terraform/
terraform.tfvars

# Vault / Doppler
.doppler.yaml
.vault-token
vault-token

# Docker secrets
docker-compose.override.yml
docker-compose.*.yml
!docker-compose.yml

# SSH
.ssh/

# GPG
.gnupg/

# ══════════════════════════════════════
# DATABASES
# ══════════════════════════════════════

*.db
*.sqlite
*.sqlite3
state.db
*.sql.bak
*.dump
*.sql.gz

# ══════════════════════════════════════
# GO
# ══════════════════════════════════════

bin/
vendor/
*.exe
*.exe~
*.dll
*.so
*.dylib
__debug_bin*
coverage.out
coverage.html
sbom-go.txt

# ══════════════════════════════════════
# PYTHON
# ══════════════════════════════════════

__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
.eggs/
*.egg-info/
**/egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
sbom-python.txt

# ══════════════════════════════════════
# SECURE FILE DROP ZONE
# ══════════════════════════════════════

.secrets/

# ══════════════════════════════════════
# ARCHIVED STARTERS (from setup.sh)
# ══════════════════════════════════════

.archived/

# ══════════════════════════════════════
# HOOK TRACKING
# ══════════════════════════════════════

.last-hook-run

# ══════════════════════════════════════
# IDE / EDITOR
# ══════════════════════════════════════

.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.bak
*.tmp
*.orig

# ══════════════════════════════════════
# REPORTS / ARTIFACTS / LOGS
# ══════════════════════════════════════

reports/
data/
*.log
tmp/
*.pid
*.seed
*.pid.lock

# ══════════════════════════════════════
# MEMORY COMPILER (auto-generated)
# ══════════════════════════════════════

# Daily conversation logs (personal, auto-generated)
daily/

# Compiled knowledge base (personal, auto-generated)
knowledge/concepts/
knowledge/connections/
knowledge/qa/

# Memory compiler runtime state
.claude/memory/scripts/state.json
.claude/memory/scripts/last-flush.json
.claude/memory/scripts/flush.log
.claude/memory/scripts/compile.log
.claude/memory/scripts/session-flush-*
.claude/memory/scripts/flush-context-*
.claude/memory/.venv/
.claude/memory/uv.lock

# Exception: memory compiler config is not a secrets file
!.claude/memory/scripts/config.py

# ══════════════════════════════════════
# NODE (if JS/TS added later)
# ══════════════════════════════════════

node_modules/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock

# Stack lock (set by make init)
.stack

# Blueprint state (set by make new)
.blueprint
.blueprint-rules.md

# Room coordination (ephemeral agent messages and activity)
rooms/*/inbox/*.md
rooms/*/outbox/*.md
rooms/activity.md
!rooms/*/inbox/.gitkeep
!rooms/*/outbox/.gitkeep
