# === CW Secure Framework — Environment Variables ===
# This file is safe to commit. Real values go in .env (which is gitignored).

# === App ===
PORT=8080

# === Auth Mode ===
# DEV_MODE=true uses a fake test user locally (no Okta needed).
# Set to false when deploying with real Okta credentials.
DEV_MODE=true

# === Auth (Okta OIDC) ===
# Get these from IT after filing a Freshservice ticket.
# Not needed when DEV_MODE=true.
OKTA_ISSUER=https://coreweave.okta.com/oauth2/default
OKTA_CLIENT_ID=
OKTA_AUDIENCE=api://default

# === Database (if needed) ===
DATABASE_URL=

# === Security ===
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000

# === Environment ===
ENV=development

# === Secrets ===
# In production, secrets come from Doppler via External Secrets Operator.
# Locally, fill in values here. NEVER commit .env with real values.
