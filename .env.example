# === Required ===
PORT=8080

# === Auth (Okta OIDC) ===
# Get these from your Okta admin: https://coreweave.okta.com
OKTA_ISSUER=https://coreweave.okta.com/oauth2/default
OKTA_CLIENT_ID=
OKTA_AUDIENCE=api://default

# === Database (if needed) ===
DATABASE_URL=

# === Security ===
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000

# === Environment ===
ENV=development

# === Secrets (use Doppler in production) ===
# In production, these come from Doppler via External Secrets Operator.
# Locally, fill in values here. NEVER commit this file with real values.
